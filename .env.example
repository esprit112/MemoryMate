# .env.example
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
PORT=3000

# Database
# For production (Supabase/Postgres)
POSTGRES_URL=postgres://user:password@host:port/database?sslmode=require

# Persistent Storage (Docker/Local SQLite)
# Defaults to /data if it exists, otherwise ./data
DB_PATH=
USERS_BASE_DIR=
VAPID_KEYS_PATH=
